rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: contributions
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - description: string (required, 1-2000 chars)
    //   - lat: number (required)
    //   - lng: number (required)
    //   - authorId: string (required, immutable)
    //   - authorName: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "dark.lhian@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidContribution(data) {
      return data.keys().hasAll(['title', 'description', 'lat', 'lng', 'authorId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             data.lat is number && data.lng is number &&
             data.authorId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /contributions/{docId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidContribution(request.resource.data);
      allow update: if isAuthenticated() && 
                      isValidContribution(request.resource.data) && 
                      (isOwner(resource.data.authorId) || isAdmin()) &&
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && (isOwner(resource.data.authorId) || isAdmin());
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
